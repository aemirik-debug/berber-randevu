{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "dotenv -e .env.development -- expo start",
    "start:android:emulator": "dotenv -e .env.android-emulator -- expo start --android",
    "start:android:device": "dotenv -e .env.android-device -- expo start --android",
    "start:ios:simulator": "dotenv -e .env.ios-simulator -- expo start --ios",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@react-native/metro-config": "^0.85.2",
    "dotenv-cli": "^7.4.4"
  },
  "private": true
}
