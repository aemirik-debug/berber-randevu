{
  "hosting": {
    "public": "build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/socket.io/**",
        "run": {
          "serviceId": "berbergo-servis",
          "region": "europe-west3"
        }
      },
      {
        "source": "/barber/**",
        "run": {
          "serviceId": "berbergo-servis",
          "region": "europe-west3"
        }
      },
      {
        "source": "/custom/**",
        "run": {
          "serviceId": "berbergo-servis",
          "region": "europe-west3"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}